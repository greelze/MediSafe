    console.error("Canvas element not found!");
    return;
  }
  
  analyticsChart = new Chart(canvas.getContext("2d"), {
    type: "line",
    data: {
      labels: [],
      datasets: [
         { 
           label: "Temperature (°C)", 
           data: [], 
           borderColor: "#FF0531", 
